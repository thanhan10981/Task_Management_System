# Database
DATABASE_URL=postgresql://taskmgr:taskmgr123@localhost:5432/task_management
DB_USER=taskmgr
DB_PASSWORD=taskmgr123
DB_NAME=task_management

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Mail (anti-leak sender setup)
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_USER=no-reply@your-domain.com
SMTP_PASS=your_smtp_password
MAIL_PUBLIC_FROM_NAME=Task Management
MAIL_PUBLIC_FROM_ADDRESS=no-reply@your-domain.com

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
MAIL_QUEUE_NAME=mail-queue

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ALLOWED_PREFIXES=tasks,projects,avatars

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
# Optional fallback used when gemini-2.5-flash is temporarily overloaded.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
