# Database
DATABASE_URL=postgresql://taskmgr:taskmgr123@localhost:5432/task_management
DB_USER=taskmgr
DB_PASSWORD=taskmgr123
DB_NAME=task_management

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# App
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Firebase Auth
FIREBASE_PROJECT_ID=task-management-system-gg

# Redis / BullMQ
REDIS_URL=rediss://default:PASSWORD@suited-minnow-70405.upstash.io:6379
MAIL_QUEUE_NAME=mail-queue

# Mail (Resend)
RESEND_API_KEY=re_your_resend_api_key
MAIL_PUBLIC_FROM_NAME=Task Management
# Use a sender from a verified Resend domain in production.
MAIL_PUBLIC_FROM_ADDRESS=no-reply@mail.vothanhan.dev
REMINDER_THRESHOLDS_MINUTES=60,15,5
RESET_PASSWORD_CODE_EXPIRES_MINUTES=15



# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_ALLOWED_PREFIXES=tasks,projects,avatars

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key
# Optional fallback used when gemini-2.5-flash is temporarily overloaded.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
