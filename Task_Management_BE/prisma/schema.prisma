// Task Management System Database Schema
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED

  @@map("project_status")
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
  GUEST

  @@map("project_member_role")
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("task_priority")
}

enum ThemeMode {
  LIGHT
  DARK
  SYSTEM

  @@map("theme_mode")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_COMMENTED
  FILE_SHARED
  SYSTEM

  @@map("notification_type")
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  ARCHIVED

  @@map("sprint_status")
}

// ============================================
// Models
// ============================================

model User {
  id           String   @id @default(uuid())
  fullName     String   @db.VarChar(150)
  email        String   @unique @db.VarChar(255)
  passwordHash String?  @db.Text
  avatarUrl    String?  @db.Text
  coverUrl     String?  @db.Text
  jobTitle     String?  @db.VarChar(120)
  phone        String?  @db.VarChar(30)
  bio          String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  userSettings           UserSettings?
  projectsCreated        Project[]       @relation("createdBy")
  projectMembers         ProjectMember[]
  tasksCreated           Task[]          @relation("createdBy")
  tasksUpdated           Task[]          @relation("updatedBy")
  taskAssignees          TaskAssignee[]
  comments               Comment[]
  taskHistory            TaskHistory[]
  filesUploaded          File[]
  notifications          Notification[]
  projectMemberAddedBy   ProjectMember[] @relation("addedBy")
  taskAssigneeAssignedBy TaskAssignee[]  @relation("assignedBy")
  sprintsCreated         Sprint[]        @relation("sprintCreatedBy")

  @@map("users")
}

model UserSettings {
  userId               String    @id
  notificationSettings Json?
  privacySettings      Json?
  preferences          Json?
  theme                ThemeMode @default(SYSTEM)
  updatedAt            DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("user_settings")
}

model Project {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(180)
  description String?       @db.Text
  status      ProjectStatus @default(ACTIVE)
  color       String?       @db.VarChar(20)
  icon        String?       @db.VarChar(50)
  createdBy   String
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @db.Timestamptz(6)

  // Relations
  creator       User            @relation("createdBy", fields: [createdBy], references: [id], onDelete: Cascade)
  members       ProjectMember[]
  taskGroups    TaskGroup[]
  tasks         Task[]
  taskStatuses  TaskStatus[]
  files         File[]
  notifications Notification[]
  sprints       Sprint[]

  @@map("projects")
}

model Sprint {
  id          String       @id @default(uuid())
  projectId   String
  name        String       @db.VarChar(150)
  goal        String?      @db.Text
  description String?      @db.Text
  status      SprintStatus @default(PLANNING)
  startDate   DateTime?    @db.Timestamptz(6)
  endDate     DateTime?    @db.Timestamptz(6)
  completedAt DateTime?    @db.Timestamptz(6)
  createdBy   String?
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(6)

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User?   @relation("sprintCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  tasks   Task[]

  @@unique([projectId, name])
  @@index([projectId, status])
  @@map("sprints")
}

model ProjectMember {
  id        String            @id @default(uuid())
  projectId String
  userId    String
  role      ProjectMemberRole @default(MEMBER)
  joinedAt  DateTime          @default(now()) @db.Timestamptz(6)
  addedBy   String?

  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  addedByUser User?   @relation("addedBy", fields: [addedBy], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@map("project_members")
}

model TaskStatus {
  id        String   @id @default(uuid())
  projectId String
  name      String   @db.VarChar(100)
  color     String?  @db.VarChar(20)
  position  Int
  isDefault Boolean  @default(false)
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@unique([projectId, position])
  @@map("task_statuses")
}

model TaskGroup {
  id          String   @id @default(uuid())
  projectId   String
  name        String   @db.VarChar(120)
  description String?  @db.Text
  color       String?   @db.VarChar(20)
  position    Int
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@unique([projectId, position])
  @@index([projectId])
  @@map("task_groups")
}

model Task {
  id           String       @id @default(uuid())
  projectId    String
  sprintId     String?
  groupId      String?
  parentTaskId String?
  title        String       @db.VarChar(255)
  description  String?      @db.Text
  statusId     String
  priority     TaskPriority @default(MEDIUM)
  progress     Decimal      @default(0) @db.Decimal(5, 2)
  startDate    DateTime?    @db.Timestamptz(6)
  dueDate      DateTime?    @db.Timestamptz(6)
  tags         Json?
  checklist    Json?
  coverFileId  String?
  isDeleted    Boolean      @default(false)
  createdBy    String
  updatedBy    String?
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(6)

  // Relations
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint        Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  group         TaskGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parentTask    Task?          @relation("parentSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks      Task[]         @relation("parentSubtasks")
  status        TaskStatus     @relation(fields: [statusId], references: [id], onDelete: Restrict)
  createdByUser User           @relation("createdBy", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedByUser User?          @relation("updatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  assignees     TaskAssignee[]
  comments      Comment[]
  history       TaskHistory[]
  files         File[]

  @@index([projectId])
  @@index([statusId])
  @@index([createdBy])
  @@index([projectId, sprintId])
  @@index([groupId])
  @@index([sprintId, statusId])
  @@map("tasks")
}

model TaskAssignee {
  id         String   @id @default(uuid())
  taskId     String
  userId     String
  assignedBy String?
  assignedAt DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  task           Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("assignedBy", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@unique([taskId, userId])
  @@map("task_assignees")
}

model Comment {
  id              String   @id @default(uuid())
  taskId          String
  userId          String
  parentCommentId String?
  content         String   @db.Text
  attachments     Json?
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment Comment?  @relation("parentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[] @relation("parentReplies")
  files         File[]

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}

model TaskHistory {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  actionType String   @db.VarChar(50) @map("action_type")
  metadata   Json?
  createdAt  DateTime @default(now()) @db.Timestamptz(6) @map("created_at")

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([taskId, createdAt])
  @@index([actionType])
  @@map("task_history")
}

model File {
  id              String   @id @default(uuid())
  projectId       String
  uploadedBy      String?
  fileName        String   @db.VarChar(255)
  fileType        String?  @db.VarChar(100)
  fileCategory    String?  @db.VarChar(50)
  fileUrl         String   @db.Text
  thumbnailUrl    String?  @db.Text
  sizeBytes       BigInt?
  durationSeconds Int?
  storageProvider String   @default("cloudinary") @db.VarChar(50)
  storageKey      String?  @db.Text
  folderPath      String?  @db.VarChar(255)
  sharedWith      Json?
  taskId          String?
  commentId       String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  // Relations
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment  Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([taskId])
  @@map("files")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  projectId String?
  type      NotificationType
  title     String?          @db.VarChar(255)
  content   String?          @db.Text
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?        @db.Timestamptz(6)
  createdAt DateTime         @default(now()) @db.Timestamptz(6)

  // Relations
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@map("notifications")
}

