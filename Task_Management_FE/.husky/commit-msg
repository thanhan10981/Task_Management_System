#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Enforce Conventional Commits format:
# type(scope?): subject
# Examples: feat(auth): add login page | fix: correct typo | chore: update deps
COMMIT_MSG=$(cat "$1")
PATTERN='^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert)(\(.+\))?: .{1,80}$'

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ Invalid commit message format!"
  echo ""
  echo "   Expected: <type>(<scope>): <subject>"
  echo "   Types: feat, fix, docs, style, refactor, perf, test, chore, build, ci, revert"
  echo ""
  echo "   Examples:"
  echo "     feat(auth): add login form"
  echo "     fix: resolve task status bug"
  echo "     chore: update dependencies"
  echo ""
  exit 1
fi
